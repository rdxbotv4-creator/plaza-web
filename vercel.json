{
    "builds": [
        {
            "src": "**/*.html",
            "use": "@vercel/static"
        },
        {
            "src": "assets/**",
            "use": "@vercel/static"
        },
        {
            "src": "data/**",
            "use": "@vercel/static"
        },
        {
            "src": "cache/**",
            "use": "@vercel/static"
        },
        {
            "src": "list/**",
            "use": "@vercel/static"
        },
        {
            "src": "manifest.json",
            "use": "@vercel/static"
        },
        {
            "src": "sw.js",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/",
            "dest": "/index.html"
        },
        {
            "src": "/index.html",
            "dest": "/index.html"
        },
        {
            "src": "/data/(.*)",
            "dest": "/data/$1"
        },
        {
            "src": "/list/(.*)",
            "dest": "/list/$1"
        },
        {
            "src": "/admin-login",
            "dest": "/admin-login.html"
        },
        {
            "src": "/admin-dashboard",
            "dest": "/admin-dashboard.html"
        },
        {
            "src": "/portal",
            "dest": "/portal.html"
        },
        {
            "src": "/admin",
            "dest": "/admin-login.html"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Service-Worker-Allowed",
                    "value": "/"
                }
            ]
        }
    ]
}